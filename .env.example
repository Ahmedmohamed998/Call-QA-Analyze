# ============================================================
# AI Call Quality Analyzer — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.3-chat

# --- AWS Bedrock (Claude) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BEDROCK_REGION=us-east-1
AWS_BEDROCK_INFERENCE_PROFILE_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# --- General ---
# Which LLM provider to use: "azure_openai" or "bedrock_claude"
LLM_PROVIDER=azure_openai
LOG_LEVEL=INFO
